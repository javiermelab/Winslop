<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslop.Views.InstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Row 0: Category filter -->
        <!-- Row 0: Toolbar — category chip + filter chips -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <ComboBox x:Name="comboCategory"
                      x:Uid="ComboCategory" FontSize="11" FontWeight="SemiBold" Height="28"
                      CornerRadius="6" Padding="8,0"
                      SelectionChanged="comboCategory_SelectionChanged" />
            <ToggleButton x:Name="chkInstalledOnly" x:Uid="ChkInstalledOnly"
                          CornerRadius="6" Padding="8,4" FontSize="11" FontWeight="SemiBold"
                          Checked="chkFilter_Changed" Unchecked="chkFilter_Changed" />
            <ToggleButton x:Name="chkUpgradesOnly" x:Uid="ChkUpgradesOnly"
                          CornerRadius="6" Padding="8,4" FontSize="11" FontWeight="SemiBold"
                          Checked="chkFilter_Changed" Unchecked="chkFilter_Changed" />
        </StackPanel>

        <!-- Row 2: Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
            <Button x:Name="btnInstall"         x:Uid="BtnInstall"     Click="btnInstall_Click"         FontSize="11" Padding="8,4" />
            <Button x:Name="btnUpgradeSelected" x:Uid="BtnUpgradeSelected"     Click="btnUpgradeSelected_Click" FontSize="11" Padding="8,4" />
            <Button x:Name="btnUpgradeAll"      x:Uid="BtnUpgradeAll" Click="btnUpgradeAll_Click"      FontSize="11" Padding="8,4" />
            <Button x:Name="btnUninstall"       x:Uid="BtnUninstall"   Click="btnUninstall_Click"       FontSize="11" Padding="8,4" />
        </StackPanel>

        <!-- Row 3: Table (header + list in one border) -->
        <Border Grid.Row="3"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0" CornerRadius="4">
            <Grid RowDefinitions="Auto,*">

                <!-- Column headers, damn so this must match my DataTemplate column widths exactly -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="32,2*,3*,90,90"
                      Padding="12,6,12,6"
                      BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <TextBlock Grid.Column="1" x:Uid="ColAppName"   FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="2" x:Uid="ColPackageId" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="3" x:Uid="ColInstalled"  FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="4" x:Uid="ColUpdate"     FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <!-- App list: column definitions MUST match header above -->
                <ListView Grid.Row="1" x:Name="listApps" SelectionMode="None" IsItemClickEnabled="True"
          ItemClick="listApps_ItemClick" Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"   Value="12,0" />
                            <Setter Property="MinHeight" Value="36" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:InstallEntry">
                            <Grid ColumnDefinitions="32,2*,3*,90,90" VerticalAlignment="Center">

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                          MinWidth="0" MinHeight="0" Margin="0" />

                                <!-- App name -->
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                           VerticalAlignment="Center" FontSize="11"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Package ID -->
                                <TextBlock Grid.Column="2" Text="{x:Bind WingetId}"
                                           VerticalAlignment="Center"
                                           FontSize="10" Opacity="0.6"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Installed -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind InstalledLabel, Mode=OneWay}"
                                           Foreground="{x:Bind InstalledColor, Mode=OneWay}"
                                           VerticalAlignment="Center" FontSize="11" />

                                <!-- Update available -->
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind UpdateLabel, Mode=OneWay}"
                                           Foreground="{x:Bind UpdateColor, Mode=OneWay}"
                                           VerticalAlignment="Center" FontSize="11" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Page>
