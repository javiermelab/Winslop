<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslop.Views.FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslop"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Page.Resources>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        <local:StatusToBrushConverter x:Key="StatusToBrushConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar: profile chip + issues filter -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
                    Margin="0,0,0,8" VerticalAlignment="Center">

            <ComboBox x:Name="comboProfiles" x:Uid="ComboProfiles"
                      FontSize="11" FontWeight="SemiBold" Height="28"
                      CornerRadius="6" Padding="8,0" />

            <ToggleButton x:Name="chkIssuesOnly" x:Uid="ChkIssuesOnly"
                          CornerRadius="6" Padding="8,4" FontSize="11" FontWeight="SemiBold"
                          IsEnabled="False"
                          Checked="chkIssuesOnly_Changed" Unchecked="chkIssuesOnly_Changed" />
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0" CornerRadius="4" Padding="4">

            <TreeView x:Name="treeFeatures" SelectionMode="None">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="local:FeatureTreeItem">
                        <TreeViewItem ItemsSource="{x:Bind FilteredChildren}"
                                      IsExpanded="True">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <CheckBox IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                          IsEnabled="{x:Bind IsApplicableOnOS}"
                                          MinWidth="0" MinHeight="0" Padding="4,0,0,0" />

                                <!-- Status badge (rounded square) -->
                                <Border Width="10" Height="10" CornerRadius="3" VerticalAlignment="Center"
                                        Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource StatusToBrushConverter}}" />

                                <!-- Action button: icon + chevron -->
                                <Button Tag="{x:Bind}" Click="ItemMenuButton_Click"
                                        Height="25" Padding="5,2" CornerRadius="6"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                                </Button>

                                <TextBlock Text="{x:Bind Name}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="{x:Bind IsCategory, Converter={StaticResource BoolToFontWeightConverter}}" />
                                <TextBlock Text="{x:Bind ApplicabilityText}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </Grid>
</Page>