<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslop.Views.AppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winslop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Display mode selector (replaces comboDisplayMode) -->
        <ComboBox x:Name="comboDisplayMode" Grid.Row="0"
                  x:Uid="ComboDisplayMode" FontSize="11" FontWeight="SemiBold" Height="28"
                  CornerRadius="6" Padding="8,0" Margin="0,0,0,8" />

        <Grid Grid.Row="1">
            <!-- App list -->
            <Border BorderThickness="0" CornerRadius="4" Padding="4">
                <ListView x:Name="listApps" SelectionMode="None" IsItemClickEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:AppItem">
                            <!-- Whole row is clickable as label is CheckBox content -->
                            <CheckBox IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                      Content="{x:Bind DisplayName}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0" FontSize="11" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Loading spinner: visible only while scanning -->
            <ProgressRing x:Name="scanSpinner" IsActive="False" Visibility="Collapsed"
                          HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40" />
        </Grid>
    </Grid>
</Page>